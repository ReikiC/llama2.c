# generated build output — C binaries, object files, and pytest scratch
# (captured stdout/err, downloaded test fixtures). The Makefile, build_msvc.bat
# and tests/test_all.py all write here, so the repo root stays clean.
/build/

# Python (managed by uv: see pyproject.toml + uv.lock, which ARE committed)
.venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# generated training checkpoints (train.py writes here by default)
/out/

# OS
.DS_Store

# Data
/data/